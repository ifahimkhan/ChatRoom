CREATE TABLE RoomEntity (
    id TEXT NOT NULL PRIMARY KEY,
    name TEXT NOT NULL,
    created_by TEXT,
    created_at TEXT NOT NULL,
    updated_at TEXT NOT NULL
);

CREATE INDEX rooms_updated_idx ON RoomEntity(updated_at);

selectAll:
SELECT * FROM RoomEntity ORDER BY updated_at DESC;

upsert:
INSERT OR REPLACE INTO RoomEntity(id, name, created_by, created_at, updated_at)
VALUES (?, ?, ?, ?, ?);

deleteAll:
DELETE FROM RoomEntity;

deleteById:
DELETE FROM RoomEntity WHERE id = ?;
